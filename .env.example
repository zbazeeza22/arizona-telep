# Supabase Configuration
# CRITICAL: Never commit the actual .env file to version control
# Copy this file to .env and fill in your actual values

# Supabase Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (from Supabase Dashboard > Settings > API)
# This key is safe to use in serverless functions as it has RLS protection
SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase Service Role Key (from Supabase Dashboard > Settings > API)
# WARNING: This key bypasses RLS - use ONLY in secure server environments
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Encryption Configuration
# Generate a secure random key: openssl rand -base64 32
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Session Configuration
SESSION_SECRET=your-session-secret-here
SESSION_TIMEOUT_MINUTES=15

# Audit Logging
AUDIT_LOG_ENABLED=true

# Environment
NODE_ENV=production
